# Environment Variables — Bluecoderhub
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.

# ─────────────────────────────────────────────
# Anthropic AI (used in Admin CMS only)
# Get your key at https://console.anthropic.com
# ─────────────────────────────────────────────
VITE_ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Application URL (no trailing slash)
# ─────────────────────────────────────────────
VITE_APP_URL=https://bluecoderhub.com

# ─────────────────────────────────────────────
# Admin Password
# 
# SECURITY: Use a SHA-256 hash, NOT a plain-text password.
# To generate a hash, run this in the browser console:
#
#   const hash = async (p) => {
#     const buf = await crypto.subtle.digest('SHA-256',
#       new TextEncoder().encode(p + 'BCH_SALT_2025'));
#     return [...new Uint8Array(buf)].map(b=>b.toString(16).padStart(2,'0')).join('');
#   };
#   hash('YourStrongPassword!').then(console.log);
#
# Then paste the resulting 64-character hex string below.
# ─────────────────────────────────────────────
VITE_ADMIN_PASSWORD=
